{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "okey_ai",
	"version": "0.1.0",
	"identifier": "com.okey.dev",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:3000",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"windows": [
			{
				"title": "okey_ai",
				"label": "main",
				"url": "/",
				"width": 50,
				"height": 50,
				"resizable": false,
				"fullscreen": false,
				"visible": false,
				"skipTaskbar": true,
				"decorations": false,
				"transparent": true,
				"hiddenTitle": true,
				"shadow": false,
				"alwaysOnTop": true,
				"minimizable": false,
				"maximizable": false,
				"closable": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
